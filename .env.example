# Compose host-side interpolation (copy → .env next to docker-compose.yml).
# Demo-only defaults — change before any shared/networked use.
# App runtime secrets also live in .env.docker (env_file on `app`).

MYSQL_DATABASE=pdv
MYSQL_USER=pdv
MYSQL_PASSWORD=pdv_secret
MYSQL_ROOT_PASSWORD=root_secret
REDIS_PASSWORD=pdv_redis_secret

# App boot (passed into `app` service)
MIGRATE_ON_BOOT=true
SEED_ON_BOOT=true
DOCKER_STRICT=false
