# Production template — copy to backend/.env (never commit secrets).
# See docs/ops/production-hardening.md
# Boot fails closed if APP_ENV=production and APP_DEBUG/SESSION_SECURE_COOKIE are wrong.

APP_NAME=PDV
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://pdv.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=pdv
DB_USERNAME=pdv
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.example.com
SESSION_HTTP_ONLY=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

PASSWORD_UNCOMPROMISED=true

SANCTUM_STATEFUL_DOMAINS=pdv.example.com

QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379

TELESCOPE_ENABLED=false
PULSE_ENABLED=false

IDEMPOTENCY_RETENTION_DAYS=7

PAYMENT_WEBHOOK_SECRET=
CUSTOMER_PII_ENCRYPTION_KEY=
CUSTOMER_PII_BLIND_INDEX_KEY=

PAYMENTS_SOAP_MODE=stub
PAYMENTS_ASYNC_SETTLEMENT=true
PAYMENTS_RECONCILE_DRIVER=redis

MAIL_MAILER=smtp
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"
