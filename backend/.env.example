APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Production: APP_ENV=production APP_DEBUG=false SESSION_SECURE_COOKIE=true
# (boot guard + checklist: docs/ops/production-hardening.md; template: .env.production.example)
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
# LOG_STACK=single,structured
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_HTTP_ONLY=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:5174,localhost:5175,127.0.0.1,127.0.0.1:5173,127.0.0.1:5174,127.0.0.1:5175,127.0.0.1:8000

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=pdv-local
REVERB_APP_KEY=pdv-local-key
REVERB_APP_SECRET=pdv-local-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
# Fallback without Redis: QUEUE_CONNECTION=database
CONCURRENCY_DRIVER=process

TELESCOPE_ENABLED=false
PULSE_ENABLED=false

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
# Docker Compose uses REDIS_PASSWORD from projects/pdv/.env.docker (default pdv_redis_secret).
REDIS_PASSWORD=null
REDIS_PORT=6379

# Idempotency replay store retention (RN-073); daily `idempotency:purge`
IDEMPOTENCY_RETENTION_DAYS=7

# HMAC secret for POST /api/webhooks/payments/{provider}
PAYMENT_WEBHOOK_SECRET=local-payment-webhook-secret

# LGPD — customer PII (generate: php -r "echo 'base64:'.base64_encode(random_bytes(32)), PHP_EOL;")
CUSTOMER_PII_ENCRYPTION_KEY=
CUSTOMER_PII_BLIND_INDEX_KEY=

# Outbound payment acquirer (SOAP). App API + webhooks stay REST.
PAYMENTS_SOAP_MODE=stub
# PAYMENTS_SOAP_WSDL=
# PAYMENTS_SOAP_ENDPOINT=
# PAYMENTS_SOAP_NAMESPACE=urn:pdv:payments

# Async settlement outbox (Redis) + hourly reconcile fallback
PAYMENTS_ASYNC_SETTLEMENT=true
PAYMENTS_RECONCILE_DRIVER=redis

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
