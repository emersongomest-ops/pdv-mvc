VITE_REVERB_APP_KEY=pdv-local-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# Optional fallback; API also returns turnstile_site_key when captcha_required.
# Cloudflare test (always pass): 1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=

# Idle session UX (minutes). Stricter than SESSION_LIFETIME for shared POS.
# Set VITE_IDLE_LOGOUT_MINUTES=0 to disable.
VITE_IDLE_WARNING_MINUTES=14
VITE_IDLE_LOGOUT_MINUTES=15
