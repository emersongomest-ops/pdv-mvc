# Copy to projects/pdv/.env.docker (gitignored).
# Used by docker compose for the Laravel `app` service. Do NOT put GitHub/MCP tokens here.
# Also copy .env.example → .env for Compose interpolation (MySQL/Redis passwords).

APP_NAME=PDV
APP_ENV=local
APP_KEY=
# Leave empty in Docker: entrypoint persists a key under storage/app/.docker_app_key (volume).
# For a fixed key across volume resets, paste `php artisan key:generate --show` here.
APP_DEBUG=true
# Production: see docs/ops/production-hardening.md and backend/.env.production.example
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=pdv
DB_USERNAME=pdv
DB_PASSWORD=pdv_secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_HTTP_ONLY=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

PASSWORD_UNCOMPROMISED=true

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=redis
CACHE_STORE=redis
FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=pdv_redis_secret
REDIS_PORT=6379

PAYMENT_WEBHOOK_SECRET=local-payment-webhook-secret

CUSTOMER_PII_ENCRYPTION_KEY=
CUSTOMER_PII_BLIND_INDEX_KEY=
PAYMENTS_SOAP_MODE=stub
# PAYMENTS_SOAP_WSDL=
# PAYMENTS_SOAP_ENDPOINT=
# PAYMENTS_SOAP_NAMESPACE=urn:pdv:payments
PAYMENTS_ASYNC_SETTLEMENT=true
PAYMENTS_RECONCILE_DRIVER=redis

MAIL_MAILER=log
TELESCOPE_ENABLED=false
PULSE_ENABLED=false

# Boot behaviour (also overridable via Compose `.env`)
MIGRATE_ON_BOOT=true
SEED_ON_BOOT=true
DOCKER_STRICT=false
